{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "-c",
                "src/main.cpp",
                "-o",
                "main.o",
                "-I",
                "libs/glfw/include",
                "-I",
                "libs/glad/include",
                "-I",
                "libs/glm"
            ],
            "group": "build"
        },
        {
            "label": "Build GLAD",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "-c",
                "libs/glad/src/glad.c",
                "-o",
                "glad.o",
                "-I",
                "libs/glad/include"
            ],
            "group": "build"
        },
        {
            "label": "Link Game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "main.o",
                "glad.o",
                "-o",
                "game.exe",
                "-L",
                "libs/glfw/lib-mingw-w64",
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",
                "-luser32",
                "-lkernel32"
            ],
            "group": "build",
            "dependsOn": [
                "Build Game",
                "Build GLAD"
            ]
        },
        {
            "label": "Build All",
            "dependsOn": [
                "Link Game"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "${workspaceFolder}/libs/glad/src/glad.c",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I",
                "${workspaceFolder}/libs/glad/include",
                "-I",
                "${workspaceFolder}/libs/glfw/include",
                "-I",
                "${workspaceFolder}/libs/glm",
                "-L",
                "${workspaceFolder}/libs/glfw/lib-arm64",
                "-lglfw3",
                "-framework",
                "OpenGL",
                "-framework",
                "Cocoa",
                "-framework",
                "IOKit",
                "-framework",
                "CoreFoundation",
                "-Wno-deprecated"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}